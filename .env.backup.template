# ============================================================
# SuperKupon Backup — Supabase + Vercel Deployment
# ============================================================
# Copy ke .env.backup + fill PLACEHOLDER values dengan real ones
# JANGAN commit file .env.backup ke git (sudah di .gitignore)

# === Database (Supabase) ===
DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# === App Config ===
APP_ENV=production
DEBUG=false
APP_NAME=SuperKupon Backup

# === Security ===
ADMIN_API_KEY=GENERATE_NEW_KEY_FOR_BACKUP_DO_NOT_REUSE_PROD
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# === Scrapers ===
SCRAPER_USE_MOCK=true
SCRAPER_REAL_OVERRIDES=google_news_promo

# === Optional Integrations (kalau mau aktif di backup) ===
# INVOLVE_ASIA_API_KEY=
# INVOLVE_ASIA_API_SECRET=
# SHOPEE_AFFILIATE_APP_ID=
# SHOPEE_AFFILIATE_SECRET=

# === DB Pool ===
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === Frontend Vercel env vars (set di Vercel dashboard, BUKAN file ini) ===
# NEXT_PUBLIC_API_BASE=https://superkupon-backup-backend.up.railway.app
# NEXT_PUBLIC_CLARITY_ID=
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_INVOLVE_ASIA_AFF_ID=1090943
