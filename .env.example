# =========================================================================
# Coupon Aggregator — Environment Configuration
# Copy file ini ke .env dan isi nilai yang sesuai.
# =========================================================================

# --- Backend (FastAPI) ---
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./coupon.db

# Set false kalau mau coba real fetch (butuh proxy untuk target high-anti-bot)
SCRAPER_USE_MOCK=true
SCRAPER_DEFAULT_INTERVAL_MINUTES=60
SCRAPER_RATE_LIMIT_SECONDS=3.0
SCRAPER_TIMEOUT_SECONDS=30

# --- Telegram Bot (opsional — kosongkan untuk disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Affiliate APIs (LEGAL path — register dulu untuk dapat credentials) ---
# Involve Asia: https://www.involve.asia/
INVOLVE_ASIA_API_KEY=
INVOLVE_ASIA_API_SECRET=

# Shopee Affiliate Open API: https://affiliate.shopee.co.id/open_api
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=

# --- Phase 5 Mobile Recon (opsional — hanya kalau pakai mobile scraper) ---
# ⚠️ Token dari refresh manual akun test, BUKAN automated login flow
TOKEN_DANA_TEST=
TOKEN_OVO_TEST=
TOKEN_TIXID_TEST=
DANA_SIGNING_KEY=
DANA_DEVICE_ID=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
