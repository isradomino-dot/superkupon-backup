# Backend API base — FastAPI uvicorn on port 8001
NEXT_PUBLIC_API_BASE=http://localhost:8001

# Supabase project credentials
# Get from: https://supabase.com → Project Settings → API
# Leave blank to disable Supabase features (app works localStorage-only fallback)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-public-key...

# Optional flags
# NEXT_PUBLIC_SW_ENABLED=true   # enable Service Worker in dev

# Web Push (optional)
# VAPID public key buat PushManager.subscribe(). Frontend bisa skip env ini —
# kalau kosong, push-notification.ts auto-fetch dari GET /push/vapid-public-key.
# Set di sini cuma kalau lo mau hindari extra roundtrip ke backend pas subscribe.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
